{
  "manifest_version": 3,
  "name": "Typing Speed Tester",
  "version": "1.0.0",
  "description": "Test your typing speed using text from any webpage. Retro-styled and lightweight.",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
